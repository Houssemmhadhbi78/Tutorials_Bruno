meta {
  name: Get Post by ID
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/posts/1
  body: none
  auth: none
}

headers {
  Accept: application/json
}

docs {
  Retrieves a single post by its ID.

  Change the last path segment (currently `1`) to any value between 1 and 100
  to fetch a different post.

  Expected response: 200 OK with a single post object.
}
